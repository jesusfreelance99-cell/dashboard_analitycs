{
  "functions": [
    {
      "source": "functions",
      "codebase": "dashboard",
      "ignore": ["node_modules", ".git", "firebase-debug.log", "*.local.js"]
    }
  ],
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
